{
 "compilerOptions": {
  "target": "es2017",
  "lib": ["es2017", "dom"],
  "allowJs": true,
  "skipLibCheck": true,
  "strict": false,
  "noEmit": true,
  "esModuleInterop": true,
  "module": "esnext",
  "moduleResolution": "bundler",
  "resolveJsonModule": true,
  "isolatedModules": true,
  "jsx": "react-jsx",
  "baseUrl": ".",
  "paths": {
    "@/*": ["./*"]
  }
},
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js"
  ],
  "extends": "expo/tsconfig.base"
}
